rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'userType', 'language', 'createdAt']) &&
             data.id == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.userType in ['shopkeeper', 'customer'] &&
             data.language in ['en', 'ur', 'ru', 'sd'] &&
             (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['shopkeeperId', 'name', 'phone', 'totalUdhaar', 'totalJama', 'trustScore', 'riskLevel', 'createdAt']) &&
             data.shopkeeperId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.totalUdhaar is number && data.totalUdhaar >= 0 &&
             data.totalJama is number && data.totalJama >= 0 &&
             data.trustScore is number && data.trustScore >= 0 && data.trustScore <= 100 &&
             data.riskLevel in ['low', 'medium', 'high'] &&
             (data.createdAt is number || data.createdAt is timestamp);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['customerId', 'shopkeeperId', 'type', 'amount', 'createdAt']) &&
             data.shopkeeperId == request.auth.uid &&
             isValidId(data.customerId) &&
             exists(/databases/$(database)/documents/customers/$(data.customerId)) &&
             data.type in ['credit', 'debit'] &&
             data.amount is number && data.amount > 0 &&
             (data.createdAt is number || data.createdAt is timestamp);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'language']) &&
                      isValidUser(incoming());
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && existing().shopkeeperId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.shopkeeperId == request.auth.uid;
      allow create: if isSignedIn() && isValidCustomer(incoming());
      allow update: if isSignedIn() && 
                      existing().shopkeeperId == request.auth.uid &&
                      incoming().shopkeeperId == existing().shopkeeperId &&
                      incoming().createdAt == existing().createdAt &&
                      (
                        // Action: Add Transaction (update balance)
                        incoming().diff(existing()).affectedKeys().hasAny(['totalUdhaar', 'totalJama', 'lastTransactionAt']) ||
                        // Action: Update Info
                        incoming().diff(existing()).affectedKeys().hasAny(['name', 'phone', 'address', 'notes', 'trustScore', 'riskLevel'])
                      );
      allow delete: if isSignedIn() && existing().shopkeeperId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && existing().shopkeeperId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.shopkeeperId == request.auth.uid;
      allow create: if isSignedIn() && isValidTransaction(incoming()) &&
                      // Relay: Verify atomicity - Customer balance must be updated in same batch or verified 
                      // In rules, we can't force the batch but we can check if the customer exists
                      existsAfter(/databases/$(database)/documents/customers/$(incoming().customerId));
      // Transactions are typically immutable
      allow update, delete: if false;
    }
  }
}
